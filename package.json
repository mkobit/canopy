{
  "name": "canopy-graph",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*",
    "tools"
  ],
  "engines": {
    "bun": "1.3.14"
  },
  "scripts": {
    "build": "tsc -b && bun --filter './apps/*' build",
    "check:versions": "bun tools/verify-versions.ts",
    "test": "bun --filter '*' test",
    "lint": "bun tools/check-commands.ts && bun run check:versions && bun openspec validate --all --no-interactive && eslint . --cache",
    "format": "prettier --write .",
    "typecheck": "bun --filter '*' typecheck",
    "prepare": "husky",
    "preinstall": "node -e \"console.error('Error: use bun'); process.exit(1)\"",
    "postinstall": "ln -sf ../typescript-native/bin/tsc node_modules/.bin/tsc"
  },
  "overrides": {
    "@typescript-eslint/utils": "8.54.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@fission-ai/openspec": "^1.3.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^11.0.0",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "@vitejs/plugin-react": "^6.0.3",
    "bun-types": "^1.3.14",
    "electron": "^43.0.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-check-file": "^3.3.1",
    "eslint-plugin-functional": "^10.0.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-promise": "^7.3.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-unicorn": "^67.0.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.8.4",
    "tsx": "^4.22.4",
    "typescript": "6.0.3",
    "typescript-native": "npm:typescript@7.0.1-rc",
    "typescript-eslint": "^8.59.1",
    "uuid": "^14.0.0",
    "vite": "^8.1.2"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
